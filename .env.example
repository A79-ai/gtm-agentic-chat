# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — your AmpUp MCP endpoint and key
# ─────────────────────────────────────────────────────────────────────────────

# Your org's AmpUp MCP server (streamable HTTP). Use your ORG subdomain, e.g.
#   https://<org>.staging.a79dev.com/mcp   (staging)
#   https://<org>.a79dev.com/mcp           (prod)
AMPUP_MCP_URL=https://<your-org>.a79dev.com/mcp

# Your AmpUp API key (sk-a79-...). This is what authenticates every tool call to
# your CRM / notetaker / knowledge base. Set it in Vercel env vars — never commit.
AMPUP_MCP_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — pick ONE LLM credential path
# ─────────────────────────────────────────────────────────────────────────────

# Path A (recommended for self-hosting): bring your own Anthropic key.
# When set, the app calls Anthropic directly and you pay Anthropic for usage.
ANTHROPIC_API_KEY=

# Path B: Vercel AI Gateway (unified billing). Needs a funded balance — the free
# tier blocks Claude even via BYOK. Used only when ANTHROPIC_API_KEY is unset.
# AI_GATEWAY_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────

# Override the model. Defaults: Anthropic path -> claude-sonnet-4-6;
# Gateway path -> anthropic/claude-sonnet-4.6.
# CHAT_MODEL=claude-sonnet-4-6

# Override the assistant's system prompt.
# SYSTEM_PROMPT=You are a helpful GTM assistant...

# Enable provider-native web search (Anthropic / Google only).
# ENABLE_WEB_SEARCH=true

# Restrict the CORS origin for the chat API (defaults to *).
# ALLOWED_ORIGIN=https://your-app.vercel.app

# Ampersand connect flow (Connectors page). Only needed if the org's
# sales_agent.ampersand_project_id / ampersand_api_key aren't set server-side.
# The api key here is the FRONTEND (UI) key — safe to expose to the browser.
# AMPERSAND_PROJECT_ID=
# AMPERSAND_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — onboarding / signup / billing feature flags
# All default ON (a fresh deploy shows signup -> trial -> onboarding -> app).
# Set to "false" to switch a surface off. NEXT_PUBLIC_* are inlined at BUILD time.
# ─────────────────────────────────────────────────────────────────────────────

# NEXT_PUBLIC_CONTACT_EMAIL=rahulb@a79.ai  # Enterprise "Contact us" mailto target
# NEXT_PUBLIC_ONBOARDING_ENABLED=true   # the 3-step setup wizard
# NEXT_PUBLIC_SIGNUP_ENABLED=true       # the "Create your workspace" page
# NEXT_PUBLIC_BILLING_ENABLED=true      # plans page + free-trial banner
# NEXT_PUBLIC_TRIAL_DAYS=14             # free-trial length
# NEXT_PUBLIC_PRICE_PRO=50              # Pro plan monthly price (display)
# NEXT_PUBLIC_BILLING_CURRENCY=USD
# NEXT_PUBLIC_TRIAL_CARD_REQUIRED=false # require a card to start the trial

# Billing provider: "demo" (default — local trial clock, no real charges) or
# "stripe" (real hosted Checkout + Customer Portal + native trials).
# NEXT_PUBLIC_BILLING_PROVIDER=demo

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Stripe (only when NEXT_PUBLIC_BILLING_PROVIDER=stripe)
# Server secrets (STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET) are server-only —
# they are NEVER read by client code. Get them from dashboard.stripe.com.
# ─────────────────────────────────────────────────────────────────────────────

# STRIPE_SECRET_KEY=sk_test_...                         # server-only
# STRIPE_WEBHOOK_SECRET=whsec_...                       # server-only (Stripe CLI / dashboard)
# STRIPE_PRICE_PRO=price_...                            # the recurring Price id for Pro
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...        # safe to expose
# NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...                # optional client mirror of STRIPE_PRICE_PRO
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app      # for Checkout success/cancel return URLs
