# Single-org bench config for the Playwright e2e suite (`pnpm test`).
# Copy to .env.e2e and fill in. The bench runs `next dev` with these values; the
# Auth0 vars are intentionally EMPTY so the app renders without login and the env
# key scopes data to one org (the chat + entity-list specs run against it).

AMPUP_MCP_URL=https://<your-org>.staging.a79dev.com/mcp
AMPUP_MCP_API_KEY=sk-a79-...

# One LLM credential (matches the app's normal config — Anthropic key wins).
AI_GATEWAY_API_KEY=
# ANTHROPIC_API_KEY=

# Keep these empty: they switch the app into multi-tenant mode, which the bench
# must not use (the login spec covers that path against a real deployment).
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_ORG=
NEXT_PUBLIC_AUTH0_AUDIENCE=
MULTI_TENANT=

# First-run overlays off so the specs land straight in the workspace (they test
# the records lists + chat, not the signup/onboarding flow).
NEXT_PUBLIC_SIGNUP_ENABLED=false
NEXT_PUBLIC_ONBOARDING_ENABLED=false
